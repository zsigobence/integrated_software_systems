{
  "name": "Final1 v3 (Perfect+ Anti-Rival)",
  "Kp": 0.35,
  "Kd": 0.45,
  "roles": {
    "fixed": [
      {
        "x": "by + bvy * 8 < 500 ? Math.max(10, 50 - (500 - by - bvy * 8) * 0.4) : 50",
        "y": "by + bvy * 8 < 500 ? Math.max(400, Math.min(495, by < 400 ? by + bvy * 8 : by)) : 445"
      },
      {
        "x": "by + bvy * 8 >= 500 ? Math.max(10, 50 - (by + bvy * 8 - 500) * 0.4) : 50",
        "y": "by + bvy * 8 >= 500 ? Math.max(505, Math.min(600, by > 600 ? by + bvy * 8 : by)) : 555"
      }
    ],
    "dynamic": {
      "sortBy": "distance_to_ball",
      "phases": [
        {
          "condition": "normBx > fieldWidth - 120 && by < 120",
          "targets": [
            { "x": "fieldWidth - 300", "y": "250" },
            { "x": "fieldWidth - 600", "y": "300" },
            { "x": "fieldWidth - 600", "y": "600" }
          ]
        },
        {
          "condition": "normBx > fieldWidth - 120 && by > fieldHeight - 120",
          "targets": [
            { "x": "fieldWidth - 300", "y": "fieldHeight - 250" },
            { "x": "fieldWidth - 600", "y": "fieldHeight - 300" },
            { "x": "fieldWidth - 600", "y": "fieldHeight - 600" }
          ]
        },
        {
          "condition": "normBx < 350 && (by < 250 || by > fieldHeight - 250)",
          "vars": {
            "cSide": "by < fieldHeight / 2 ? -1 : 1",
            "shX": "Math.max(70, normBx / 2)"
          },
          "targets": [
            { "x": "Math.max(70, normBx - 120)", "y": "Math.max(150, Math.min(fieldHeight - 150, fieldHeight / 2 + cSide * 150))" },
            { "x": "shX", "y": "fieldHeight / 2 + cSide * 80" },
            { "x": "Math.max(70, shX - 50)", "y": "fieldHeight / 2" }
          ]
        },
        {
          "condition": "normBx <= fieldWidth / 2",
          "vars": {
            "pressX": "Math.max(100, normBx - 60)",
            "coverX": "Math.min(normBx - 100, 420)"
          },
          "targets": [
            { "x": "pressX",  "y": "by" },
            { "x": "coverX",  "y": "350" },
            { "x": "coverX",  "y": "650" }
          ]
        },
        {
          "condition": "true",
          "vars": {
            "aimX": "fieldWidth",
            "modBy": "by < 80 ? 120 : (by > fieldHeight - 80 ? fieldHeight - 120 : by)",
            "aimY": "by < 80 ? (fieldHeight / 2) + 200 : (by > fieldHeight - 80 ? (fieldHeight / 2) - 200 : fieldHeight / 2)",
            "dirX": "aimX - normBx",
            "dirY": "aimY - modBy",
            "normDist": "Math.hypot(dirX, dirY) || 1",
            "nX": "dirX / normDist",
            "nY": "dirY / normDist",
            "perpX": "-nY",
            "perpY": "nX"
          },
          "targets": [
            { "x": "normBx - nX * 45", "y": "modBy - nY * 45" },
            { "x": "normBx - nX * 75 + perpX * 65", "y": "modBy - nY * 75 + perpY * 65" },
            { "x": "normBx - nX * 75 - perpX * 65", "y": "modBy - nY * 75 - perpY * 65" }
          ]
        }
      ]
    }
  }
}
