{
  "name": "Final1 v5 (Anti-Rival: Sweeper + Flank Exploit)",
  "Kp": 0.35,
  "Kd": 0.45,
  "roles": {
    "fixed": [
      {
        "x": "by + bvy * 8 < 500 ? Math.max(10, 50 - (500 - by - bvy * 8) * 0.4) : 50",
        "y": "by + bvy * 8 < 500 ? Math.max(400, Math.min(495, by < 400 ? by + bvy * 8 : by)) : 445"
      },
      {
        "x": "by + bvy * 8 >= 500 ? Math.max(10, 50 - (by + bvy * 8 - 500) * 0.4) : 50",
        "y": "by + bvy * 8 >= 500 ? Math.max(505, Math.min(600, by > 600 ? by + bvy * 8 : by)) : 555"
      },
      {
        "x": "normBx < fieldWidth / 2 ? 0 : Math.min(normBx - 300, fieldWidth - 400)",
        "y": "Math.max(55, Math.min(fieldHeight - 55, by))"
      }
    ],
    "dynamic": {
      "sortBy": "distance_to_ball",
      "phases": [
        {
          "condition": "normBx > fieldWidth - 120 && by < 120",
          "targets": [
            { "x": "Math.min(fieldWidth - 55, normBx - 30)", "y": "Math.max(55, by + 30)" },
            { "x": "fieldWidth - 110", "y": "230" }
          ]
        },
        {
          "condition": "normBx > fieldWidth - 120 && by > fieldHeight - 120",
          "targets": [
            { "x": "Math.min(fieldWidth - 55, normBx - 30)", "y": "Math.min(fieldHeight - 55, by - 30)" },
            { "x": "fieldWidth - 110", "y": "fieldHeight - 230" }
          ]
        },
        {
          "condition": "normBx < 350 && (by < 250 || by > fieldHeight - 250)",
          "vars": {
            "cSide": "by < fieldHeight / 2 ? -1 : 1",
            "shX": "Math.max(70, normBx / 2)"
          },
          "targets": [
            { "x": "Math.max(70, normBx - 120)", "y": "Math.max(150, Math.min(fieldHeight - 150, fieldHeight / 2 + cSide * 150))" },
            { "x": "shX", "y": "fieldHeight / 2" }
          ]
        },
        {
          "condition": "normBx <= fieldWidth / 2",
          "targets": [
            { "x": "Math.max(100, normBx - 60)", "y": "by" },
            { "x": "Math.min(normBx - 100, 400)", "y": "by < fieldHeight / 2 ? 700 : 300" }
          ]
        },
        {
          "condition": "normBx > fieldWidth - 250",
          "targets": [
            { "x": "normBx - 45", "y": "by" },
            { "x": "fieldWidth - 150", "y": "by < fieldHeight / 2 ? 190 : fieldHeight - 190" }
          ]
        },
        {
          "condition": "normBx > fieldWidth - 600",
          "targets": [
            { "x": "normBx - 45", "y": "by" },
            { "x": "fieldWidth - 230", "y": "by < fieldHeight / 2 ? 190 : fieldHeight - 190" }
          ]
        },
        {
          "condition": "true",
          "vars": {
            "aimX": "fieldWidth",
            "aimY": "by < fieldHeight / 2 ? 190 : fieldHeight - 190",
            "dirX": "aimX - normBx",
            "dirY": "aimY - by",
            "normDist": "Math.hypot(dirX, dirY) || 1",
            "nX": "dirX / normDist",
            "nY": "dirY / normDist"
          },
          "targets": [
            { "x": "normBx - nX * 45", "y": "by - nY * 45" },
            { "x": "Math.min(normBx + 300, fieldWidth - 200)", "y": "aimY" }
          ]
        }
      ]
    }
  }
}
